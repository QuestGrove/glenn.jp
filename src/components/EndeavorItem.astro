---
// src/components/EndeavorItem.astro
// ─────────────────────────────────────────────────────────────────────────
// One item in the endeavors list.
// Mirrors Anthony Fu's project item structure:
//   [mark]  Title
//           Description
//           → Current stage
//
// The full stage trail lives on the detail page, not here.
// ─────────────────────────────────────────────────────────────────────────

interface Props {
  slug:         string
  title:        string
  description:  string
  currentStage: string
  status:       'active' | 'paused' | 'complete'
  // Optional emoji or symbol shown on the left.
  // Set this in your markdown frontmatter: icon: "📖"
  // Defaults to a simple mark if not set.
  icon?:        string
}

const { slug, title, description, currentStage, status, icon } = Astro.props
---

<a href={`/endeavors/${slug}`} class="item" title={title}>
  <!-- Left: icon / mark -->
  <div class="mark" aria-hidden="true">
    {icon ?? '◆'}
  </div>

  <!-- Right: text -->
  <div class="body">
    <div class="title">{title}</div>
    <div class="desc">{description}</div>
    <div class="stage">→ {currentStage}</div>
  </div>
</a>

<style>
  .item {
    display: flex;
    align-items: flex-start;
    gap: 0;
    text-decoration: none;
    padding: 0.5rem 0.25rem;
    border-radius: 0.4rem;
    transition: background 0.15s;
  }
  .item:hover { background: var(--c-bg-2); }
  .item:hover .title { color: var(--c-accent); }

  /* ── Left mark ──────────────────────────────────────────────────── */
  .mark {
    padding-top: 0.15rem;
    padding-right: 1.1rem;
    font-size: 1rem;
    opacity: 0.35;
    flex-shrink: 0;
    line-height: 1.6;
    /* Active items get a green tint; paused/complete stay muted */
    color: var(--c-fg);
  }

  /* ── Right body ─────────────────────────────────────────────────── */
  .body { flex: 1; min-width: 0; }

  .title {
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .desc {
    font-size: 0.82rem;
    opacity: 0.5;
    margin-top: 0.1rem;
    line-height: 1.5;
    /* Allow description to wrap — it's usually one sentence */
    white-space: normal;
  }

  .stage {
    font-size: 0.75rem;
    margin-top: 0.25rem;
    color: var(--c-accent);
    opacity: 0.8;
  }
</style>
