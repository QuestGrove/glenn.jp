---
// src/components/TagFilter.astro
// ─────────────────────────────────────────────────────────────────────────
// Renders a row of tag buttons. Clicking one filters the writing list.
// All the filtering happens in the browser — no page reload needed.
// ─────────────────────────────────────────────────────────────────────────
interface Props {
  tags: string[]   // all unique tags across all writings
}
const { tags } = Astro.props
const sorted = [...tags].sort()
---

<div class="tag-filter" role="group" aria-label="Filter by tag">
  <button class="tag active" data-tag="all">All</button>
  {sorted.map(tag => (
    <button class="tag" data-tag={tag}>{tag}</button>
  ))}
</div>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.25rem 0 1.75rem;
  }

  .tag {
    background: var(--c-bg-2);
    border: 1px solid var(--c-border);
    border-radius: 0.3rem;
    cursor: pointer;
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 0.75rem;
    padding: 0.25rem 0.65rem;
    opacity: 0.6;
    transition: opacity 0.15s, border-color 0.15s, color 0.15s;
    color: var(--c-fg);
  }

  .tag:hover { opacity: 1; border-color: var(--c-muted); }

  .tag.active {
    opacity: 1;
    border-color: var(--c-accent);
    color: var(--c-accent);
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag')
  // Each writing list item has a data-tags attribute — a JSON array of tag strings
  const items   = document.querySelectorAll<HTMLLIElement>('[data-tags]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!

      // Update active button
      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      // Show / hide writing items
      items.forEach(item => {
        const itemTags: string[] = JSON.parse(item.dataset.tags || '[]')
        const show = tag === 'all' || itemTags.includes(tag)
        item.style.display = show ? '' : 'none'
      })
    })
  })
</script>
