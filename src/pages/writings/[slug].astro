---
import { getCollection, render } from 'astro:content'
import WritingLayout from '../../layouts/WritingLayout.astro'

export async function getStaticPaths() {
  const writings = await getCollection('writings')
  return writings.map(w => ({ params: { slug: w.id }, props: { writing: w } }))
}

const { writing }          = Astro.props
const { Content, headings } = await render(writing)
---

<WritingLayout
  title={writing.data.title}
  date={writing.data.date}
  description={writing.data.description}
  tags={writing.data.tags}
  headings={headings}
>
  <Content />
</WritingLayout>
